---
import { profile } from '../data/site';

const links = [
  { href: '#about', label: 'About' },
  { href: '#approach', label: 'AI Era' },
  { href: '#skills', label: 'Skills' },
  { href: '#work', label: 'Work' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed inset-x-0 top-0 z-50">
  <nav class="glass mx-auto mt-4 flex max-w-6xl items-center justify-between gap-4 rounded-2xl border border-[var(--color-line)] px-4 py-3 sm:px-6">
    <a href="#top" class="group flex items-center gap-2.5">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-[var(--color-surface-2)] font-display text-sm font-bold gradient-text">AT</span>
      <span class="hidden font-display text-sm font-semibold tracking-tight text-[var(--color-snow)] sm:block">
        {profile.name}
      </span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="rounded-lg px-3 py-1.5 text-sm text-[var(--color-fog)] transition-colors hover:bg-[var(--color-surface-2)] hover:text-[var(--color-snow)]"
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <a
      href={`mailto:${profile.email}`}
      class="rounded-lg border border-[var(--color-line)] bg-[var(--color-surface-2)] px-3.5 py-1.5 text-sm font-medium text-[var(--color-snow)] transition-colors hover:border-[color-mix(in_oklab,var(--color-cyan)_50%,transparent)]"
    >
      Get in touch
    </a>
  </nav>
</header>
