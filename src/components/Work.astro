---
import Section from './Section.astro';
import { projects, categories } from '../data/site';

const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);

// Group the non-featured by category, preserving category order
const grouped = categories
  .map((cat) => ({ cat, items: rest.filter((p) => p.category === cat) }))
  .filter((g) => g.items.length > 0);
---

<Section
  id="work"
  index="04"
  label="Selected work"
  title="Things I've built"
  blurb="From production AI platforms to real-time systems and developer tools. Private repos are described in full; open-source ones link straight to GitHub."
>
  <!-- Featured: AI & autonomous flagships -->
  <div class="grid gap-5 lg:grid-cols-3">
    {
      featured.map((p) => (
        <article class="card group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)]/50 p-6" data-reveal>
          <div class="absolute right-0 top-0 h-24 w-24 bg-gradient-to-bl from-[color-mix(in_oklab,var(--color-cyan)_18%,transparent)] to-transparent"></div>

          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-display text-xl font-bold text-[var(--color-snow)]">{p.name}</h3>
              <p class="mt-0.5 text-sm text-[var(--color-cyan)]">{p.tagline}</p>
            </div>
            {p.isPrivate ? (
              <span class="inline-flex shrink-0 items-center gap-1 rounded-md border border-[var(--color-line)] px-2 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-[var(--color-fog)]">
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
                Private
              </span>
            ) : (
              <a href={p.repo!} target="_blank" rel="noreferrer" class="shrink-0 text-[var(--color-fog)] transition-colors hover:text-[var(--color-snow)]" aria-label="View on GitHub">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.7.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
              </a>
            )}
          </div>

          <p class="mt-4 flex-1 text-sm leading-relaxed text-[var(--color-fog)]">{p.description}</p>

          {p.tests && (
            <div class="mt-4 inline-flex w-fit items-center gap-1.5 rounded-md border border-[color-mix(in_oklab,var(--color-emerald)_35%,var(--color-line))] bg-[color-mix(in_oklab,var(--color-emerald)_10%,transparent)] px-2 py-1 text-xs text-[var(--color-emerald)]">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {p.tests}
            </div>
          )}

          <ul class="mt-5 flex flex-wrap gap-1.5 border-t border-[var(--color-line)] pt-4">
            {p.stack.map((s) => (
              <li class="rounded-md bg-[var(--color-ink-2)] px-2 py-1 font-mono text-[0.7rem] text-[var(--color-mist)]">{s}</li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>

  <!-- Remaining work, grouped by category -->
  {
    grouped.map((g) => (
      <div class="mt-14">
        <div class="mb-5 flex items-center gap-3" data-reveal>
          <h3 class="font-display text-sm font-semibold uppercase tracking-wider text-[var(--color-mist)]">{g.cat}</h3>
          <span class="h-px flex-1 bg-[var(--color-line)]"></span>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
          {g.items.map((p) => (
            <article class="card group flex flex-col rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)]/40 p-6" data-reveal>
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h4 class="font-display text-lg font-semibold text-[var(--color-snow)]">{p.name}</h4>
                  <p class="mt-0.5 text-sm text-[var(--color-fog)]">{p.tagline}</p>
                </div>
                {p.isPrivate ? (
                  <span class="inline-flex shrink-0 items-center gap-1 rounded-md border border-[var(--color-line)] px-2 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-[var(--color-fog)]">
                    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
                    Private
                  </span>
                ) : (
                  <a href={p.repo!} target="_blank" rel="noreferrer" class="inline-flex shrink-0 items-center gap-1 rounded-md border border-[var(--color-line)] px-2 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-[var(--color-fog)] transition-colors hover:border-[color-mix(in_oklab,var(--color-cyan)_50%,transparent)] hover:text-[var(--color-snow)]">
                    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.7.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
                    Code
                  </a>
                )}
              </div>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-[var(--color-fog)]">{p.description}</p>
              <ul class="mt-4 flex flex-wrap gap-1.5">
                {p.stack.map((s) => (
                  <li class="rounded-md bg-[var(--color-ink-2)] px-2 py-1 font-mono text-[0.7rem] text-[var(--color-mist)]">{s}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    ))
  }
</Section>
