---
import { ticker } from '../data/site';
const items = [...ticker, ...ticker];
---

<div class="ticker relative overflow-hidden border-y border-[var(--color-line)] bg-[var(--color-ink-2)] py-4">
  <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-[var(--color-ink-2)] to-transparent"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-[var(--color-ink-2)] to-transparent"></div>
  <div class="ticker-track gap-8 px-4">
    {
      items.map((t) => (
        <span class="flex shrink-0 items-center gap-8 font-mono text-sm text-[var(--color-fog)]">
          {t}
          <span class="text-[var(--color-cyan)]">◆</span>
        </span>
      ))
    }
  </div>
</div>
