---
import { profile, stats } from '../data/site';
---

<section id="top" class="relative overflow-hidden">
  <div class="aurora"></div>
  <div class="absolute inset-0 zellige"></div>
  <div class="absolute inset-0 dot-grid opacity-40"></div>

  <div class="relative mx-auto flex max-w-6xl flex-col justify-center px-5 pb-20 pt-36 sm:px-8 sm:pt-44 lg:min-h-[92vh]">
    <div class="max-w-3xl" data-reveal>
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] bg-[var(--color-surface)]/60 px-3 py-1.5">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-emerald)] opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--color-emerald)]"></span>
        </span>
        <span class="label !text-[var(--color-mist)]">Available · {profile.location}</span>
      </div>

      <p class="mb-4 font-mono text-sm text-[var(--color-cyan)]">
        $ whoami<span class="cursor-blink">_</span>
      </p>

      <h1 class="font-display text-4xl font-bold leading-[1.05] tracking-tight text-[var(--color-snow)] sm:text-6xl lg:text-7xl">
        {profile.name}
      </h1>

      <p class="mt-4 font-display text-xl font-medium text-[var(--color-mist)] sm:text-2xl">
        {profile.role}
      </p>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-fog)] sm:text-xl">
        I build full-stack products and <span class="gradient-text font-semibold">autonomous systems</span> for the age of <span class="gradient-text font-semibold">AI agents</span>.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a
          href="#work"
          class="group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-[var(--color-cyan)] to-[var(--color-emerald)] px-5 py-3 font-medium text-[#04140f] transition-transform hover:scale-[1.02]"
        >
          View my work
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a
          href={profile.github}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-line)] bg-[var(--color-surface)]/60 px-5 py-3 font-medium text-[var(--color-snow)] transition-colors hover:border-[color-mix(in_oklab,var(--color-cyan)_50%,transparent)]"
        >
          <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.7.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
          GitHub
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-16 grid max-w-3xl grid-cols-2 gap-px overflow-hidden rounded-2xl border border-[var(--color-line)] bg-[var(--color-line)] sm:grid-cols-4" data-reveal>
      {
        stats.map((s) => (
          <div class="bg-[var(--color-ink-2)] px-5 py-6">
            <div class="font-display text-3xl font-bold gradient-text">{s.value}</div>
            <div class="mt-1 text-sm text-[var(--color-fog)]">{s.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
