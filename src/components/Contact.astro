---
import { profile } from '../data/site';
---

<section id="contact" class="relative mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8 sm:py-28">
  <div class="relative overflow-hidden rounded-3xl border border-[var(--color-line)] bg-[var(--color-ink-2)] px-6 py-14 sm:px-12 sm:py-20" data-reveal>
    <div class="absolute inset-0 zellige"></div>
    <div class="aurora !h-[120%] opacity-70"></div>

    <div class="relative mx-auto max-w-2xl text-center">
      <span class="label">05 — Contact</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-[var(--color-snow)] sm:text-5xl">
        Let&rsquo;s build something <span class="gradient-text">intelligent</span>.
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-[var(--color-fog)]">
        {profile.resumeNote} If you&rsquo;re working on AI products, autonomous agents, or ambitious full-stack systems, I&rsquo;d love to talk.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a
          href={`mailto:${profile.email}`}
          class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-[var(--color-cyan)] to-[var(--color-emerald)] px-6 py-3 font-medium text-[#04140f] transition-transform hover:scale-[1.02]"
        >
          <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Email me
        </a>
        <a
          href={profile.github}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-line)] bg-[var(--color-surface)]/60 px-6 py-3 font-medium text-[var(--color-snow)] transition-colors hover:border-[color-mix(in_oklab,var(--color-cyan)_50%,transparent)]"
        >
          <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.7.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
          GitHub
        </a>
        <a
          href={profile.huggingface}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-line)] bg-[var(--color-surface)]/60 px-6 py-3 font-medium text-[var(--color-snow)] transition-colors hover:border-[color-mix(in_oklab,var(--color-cyan)_50%,transparent)]"
        >
          🤗 Hugging Face
        </a>
      </div>
    </div>
  </div>
</section>
